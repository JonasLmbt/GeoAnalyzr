{
  "scripts": {
    "build": "npm run build:dev && npm run build:devfile && npm run build:release && npm run build:sync",
    "build:dev": "node scripts/build-release.cjs dist/userscript.user.js",
    "build:devfile": "node scripts/build-release.cjs geoanalyzr.dev.user.js",
    "build:release": "node scripts/build-release.cjs",
    "build:sync": "node scripts/build-release.cjs geoanalyzr.sync.user.js",
    "watch": "esbuild src/main.ts --bundle --outfile=dist/userscript.user.js --format=iife --watch"
  },
  "dependencies": {
    "@rapideditor/country-coder": "^5.6.1",
    "dexie": "^4.3.0",
    "esbuild": "^0.27.3",
    "fflate": "^0.8.2",
    "xlsx": "^0.18.5"
  }
}
